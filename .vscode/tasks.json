{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure",
            "type": "shell",
            "command": "cmake",
            "args": ["-B", "build"],
            "problemMatcher": []
        },
        {
            "label": "Compile",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--", "-j8"],
            "problemMatcher": ["$gcc"]
        },
		{
            "label": "Build",
            "dependsOrder": "sequence",
            "dependsOn": ["Configure", "Compile"],
            "problemMatcher": [],
			"group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}